# ============================================================
# Northeast Watch API — environment configuration
# Copy to .env for local dev. In production, inject these via
# your secrets manager (AWS Secrets Manager / Vault / etc.) —
# never commit a real .env file. See docs/SECURITY.md.
# ============================================================

NODE_ENV=development
PORT=4000

# --- Database ---
DATABASE_URL=postgresql://nw_user:nw_password@localhost:5432/northeast_watch

# --- Redis (cache, rate limiting, pub/sub, job queue) ---
REDIS_URL=redis://localhost:6379

# --- Auth secrets ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-a-random-64-char-hex-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-random-64-char-hex-string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Integration credential encryption key ---
# Must be exactly 32 bytes, hex-encoded (64 hex chars). Generate with:
#   openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=replace-with-64-hex-characters-exactly-32-bytes-worth

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.northeastwatch.example

# --- Rate limiting ---
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# --- Observability ---
LOG_LEVEL=info
SENTRY_DSN=

# --- Optional partner integrations ---
# These are configured at runtime via the admin console
# (PUT /api/admin/integrations/:key), NOT via environment
# variables — see docs/INTEGRATIONS.md. Left here only as a
# reference to what each integration needs.
# ASDMA_API_BASE_URL=
# ASDMA_API_KEY=
# CWC_API_BASE_URL=
# CWC_API_KEY=
# APDCL_API_BASE_URL=
# APDCL_API_KEY=
# NEWS_RSS_PROXY_URL=
